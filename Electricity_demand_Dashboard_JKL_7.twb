            <column caption='sunshine_bin' datatype='string' name='[Calculation_1237926982584889344]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [sunshine] &lt; 2.5 THEN &quot;Cloudy&quot;&#13;&#10;ELSEIF [sunshine] &gt;= 2.5 AND &#13;&#10;[sunshine] &lt; 3.8 THEN &quot;Moderate&quot;&#13;&#10;ELSE &quot;High&quot;&#13;&#10;END' />
